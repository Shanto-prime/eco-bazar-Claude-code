// prisma/schema.prisma
// Database schema for Ecobazar — MongoDB (via the Prisma `mongodb` connector).
//
// Migration notes (from the previous MySQL schema):
//   • provider is now `mongodb`. Every model MUST have an `@id` mapped to
//     Mongo's reserved `_id`. We keep the existing `cuid()` string ids and just
//     map them: `String @id @default(cuid()) @map("_id")`. This avoids churning
//     every id to ObjectId and keeps ids stable across the codebase.
//   • MongoDB has no VARCHAR ceiling, so all `@db.Text` annotations are dropped.
//   • The Mongo connector does NOT support `Decimal`. All money is stored as
//     INTEGER MINOR UNITS (cents): price 1499 == $14.99. Server-side authoritative
//     math (order totals) runs in integer cents; the data-access layer converts
//     to dollar `number`s at the boundary (lib/products-db.js `shape()`,
//     order-actions return). Never store fractional currency.
//   • Enums are supported by the Mongo connector and kept as-is.
//   • Scalar lists (`String[]` for tags) are native to MongoDB.
//   • `Json` maps to a BSON sub-document (used for specifications + audit metadata).
//   • Multi-document transactions (lib/order-actions.js `$transaction`) require a
//     REPLICA SET. MongoDB Atlas is a replica set by default; a standalone local
//     `mongod` is not and will throw. DATABASE_URL must point at Atlas or a local
//     replica set (…?replicaSet=rs0).
//
// After changing this file:  npm run db:push   (prisma db push — Mongo has no
// migration history), then  npm run db:seed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & roles
// ---------------------------------------------------------------------------
// Three roles in the system:
//   CUSTOMER  — default; can browse, cart, order, review.
//   MODERATOR — can create products. Edits/deletes are restricted to their
//               own creations. Tracked by Product.createdById.
//   ADMIN     — full control: edit/delete any product, manage users & orders,
//               view audit log.
enum Role {
  CUSTOMER
  MODERATOR
  ADMIN
}

// User record. Auth.js (NextAuth) writes Account / Session rows linking
// OAuth providers to this row. `passwordHash` is set only for credentials
// (username/email + password) signups.
//
// Identity model: credentials users have BOTH a `username` (unique login
// handle) and a real `email` (unique, required for password reset /
// verification). Login accepts either the username or the email plus the
// password. `username` is nullable because OAuth-created users (Google /
// Facebook) have an email but no username.
model User {
  id            String     @id @default(cuid()) @map("_id")
  username      String?    @unique
  email         String     @unique
  name          String?
  phone         String?    // optional contact number (collected at signup)
  image         String?    // profile photo URL (OAuth avatar or uploaded)
  emailVerified DateTime?
  passwordHash  String?    // bcrypt — null for OAuth-only users
  role          Role       @default(CUSTOMER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts      Account[]
  sessions      Session[]
  productsAdded Product[]   @relation("ProductsCreatedBy")
  orders        Order[]
  reviews       Review[]
  auditEvents   AuditLog[]  @relation("AuditActor")
  statusEvents  OrderStatusEvent[]
  addresses     Address[]
  changeRequests ProfileChangeRequest[] @relation("ChangeRequester")
  changeReviews  ProfileChangeRequest[] @relation("ChangeReviewer")
}

// ---------------------------------------------------------------------------
// Address book — saved shipping/billing addresses, managed from
// /dashboard/settings. Checkout prefills from the default one but still writes
// its own snapshot onto Order: an address edited (or deleted) later must never
// retroactively change where a past order was shipped. Same snapshot rationale
// as OrderItem.
// ---------------------------------------------------------------------------
model Address {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?  // "Home", "Office" — user-facing nickname
  firstName String
  lastName  String
  company   String?
  street    String
  city      String?
  state     String?
  zip       String?
  country   String?
  phone     String?
  // Exactly one address per user should carry this. Not expressible as a DB
  // constraint on Mongo, so _actions.js clears the flag on siblings inside a
  // transaction whenever a new default is set.
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Moderated profile changes
// ---------------------------------------------------------------------------
// Name / username / avatar edits apply instantly. Email and phone are the
// account-recovery channels, so changing either would let a hijacked session
// lock the real owner out — those go through a review queue instead
// (/dashboard/profile-requests, ADMIN + MODERATOR).
enum ProfileChangeField {
  EMAIL
  PHONE
}

enum ProfileChangeStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED   // withdrawn by the requester before review
}

model ProfileChangeRequest {
  id           String              @id @default(cuid()) @map("_id")
  userId       String
  user         User                @relation("ChangeRequester", fields: [userId], references: [id], onDelete: Cascade)
  field        ProfileChangeField
  currentValue String?             // snapshot at request time, for the reviewer's diff
  newValue     String
  status       ProfileChangeStatus @default(PENDING)
  reviewerId   String?
  reviewer     User?               @relation("ChangeReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewNote   String?
  createdAt    DateTime            @default(now())
  reviewedAt   DateTime?

  // At most one PENDING row per (user, field) — enforced in _actions.js, since
  // a partial/filtered unique index isn't expressible here.
  @@index([userId])
  @@index([status])
}

// Auth.js OAuth links — one row per (user, provider).
model Account {
  id                String  @id @default(cuid()) @map("_id")
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// NextAuth verification/reset tokens. On MongoDB every model needs an `@id`
// mapped to `_id`, so this model — which had no id under MySQL — gains one.
model VerificationToken {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Store-wide configuration — a single row (id "store"). Currently holds the
// active display currency + the admin-managed exchange rates (BASE=BDT per unit
// of each currency). Set only from the ADMIN settings page. See lib/currency.js
// and lib/store-config.js.
// ---------------------------------------------------------------------------
model StoreConfig {
  id        String   @id @map("_id")     // fixed "store" — enforces a single row
  currency  String   @default("BDT")     // active display currency code
  rates     Json?                        // { USD: 121, AED: 33 } — BDT per 1 unit
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------
model Category {
  id        String    @id @default(cuid()) @map("_id")
  slug      String    @unique
  name      String
  icon      String?   // emoji used in the homepage tiles (optional)
  products  Product[]
}

model Product {
  id          String    @id @default(cuid()) @map("_id")
  slug        String    @unique
  name        String
  description String?
  // Money in INTEGER CENTS (see file header). price 1499 == $14.99.
  price       Int
  oldPrice    Int?      // original/compare-at price; the "salePrice" convention
                        // is: `price` is what the customer pays, `oldPrice` is
                        // the struck-through original.
  badge       String?   // e.g. "Sale 50%"
  rating      Float     @default(0)
  // Inventory — `stock` is the source of truth for "is this in stock?"
  stock       Int       @default(0)

  // Merchandising / catalog metadata.
  // NOTE: `sku` is intentionally NOT `@unique`. On MongoDB a non-sparse unique
  // index treats a missing field as `null` and allows only ONE such document,
  // which would forbid more than one product without a SKU. Enforce SKU
  // uniqueness in the application layer when a value is actually supplied.
  sku            String?
  brand          String?
  tags           String[]          // native Mongo scalar list
  specifications Json?             // flexible key/value spec sheet

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  // Audit: who added this product. Required so moderators can see only their
  // own additions and the admin sees the full history.
  createdById String
  createdBy   User      @relation("ProductsCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  images      ProductImage[]
  reviews     Review[]
  orderItems  OrderItem[]

  @@index([categoryId])
  @@index([createdById])
}

// Each product has 0..N images. We store relative paths under /uploads/...
// because images are served from the same domain.
model ProductImage {
  id        String   @id @default(cuid()) @map("_id")
  productId String
  url       String
  alt       String?
  sort      Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sort])
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------
enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

// Payment lifecycle, tracked independently of fulfilment (OrderStatus) so a
// gateway can move a payment to PAID/REFUNDED without changing shipping state.
enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  COD
  PAYPAL
  AMAZON
  BKASH
  NAGAD
}

model Order {
  id            String        @id @default(cuid()) @map("_id")
  number        String        @unique   // ECO-123456 friendly id
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  email         String        // captured for guest orders too
  phone         String?
  firstName     String
  lastName      String
  street        String
  city          String?
  state         String?
  zip           String?
  country       String?

  // Money in INTEGER CENTS.
  subtotal      Int
  discount      Int           @default(0)
  shipping      Int           @default(0)
  total         Int
  couponCode    String?
  notes         String?

  payment       PaymentMethod @default(COD)
  paymentStatus PaymentStatus @default(UNPAID)
  status        OrderStatus   @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         OrderItem[]
  history       OrderStatusEvent[]

  @@index([userId])
  @@index([status])
}

// Append-only timeline of every status transition on an order. `Order.updatedAt`
// can't serve this purpose — it moves on ANY write to the row — so each change
// gets its own row with the moment it happened and who made it. The order's
// creation is itself recorded as the first event (PENDING), so the timeline is
// complete without special-casing the first entry.
model OrderStatusEvent {
  id        String      @id @default(cuid()) @map("_id")
  orderId   String
  status    OrderStatus
  // Null for the initial PENDING event (the customer/guest placing the order)
  // and for any future automated transition.
  actorId   String?
  note      String?
  createdAt DateTime    @default(now())

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor     User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// Snapshot of price+name at purchase time so historical orders don't change
// when the product is later edited or deleted.
model OrderItem {
  id          String   @id @default(cuid()) @map("_id")
  orderId     String
  productId   String?
  productSlug String   // snapshot
  productName String   // snapshot
  unitPrice   Int      // INTEGER CENTS snapshot
  qty         Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Reviews
// ---------------------------------------------------------------------------
model Review {
  id        String   @id @default(cuid()) @map("_id")
  productId String
  userId    String
  rating    Int      // 1..5
  body      String
  approved  Boolean  @default(false)   // admin moderates
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Audit log — every privileged write logs here.
// Lets the admin see exactly who did what and when.
// ---------------------------------------------------------------------------
model AuditLog {
  id         String   @id @default(cuid()) @map("_id")
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  action     String   // e.g. "product.create" | "product.update" | "order.refund"
  entity     String   // e.g. "Product" | "Order" | "User"
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}
