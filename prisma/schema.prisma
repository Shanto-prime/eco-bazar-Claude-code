// prisma/schema.prisma
// Database schema for Ecobazar.
// Run `npx prisma migrate dev --name init-mysql` after changing this file to
// update your local DB.
//
// Notes on MySQL specifics
//   • String columns default to VARCHAR(191) on MySQL. We add `@db.Text` to any
//     field that may exceed that (descriptions, addresses, OAuth tokens, audit
//     payloads, review bodies, free-form notes).
//   • Enums are emitted as MySQL `ENUM(...)` columns.
//   • `Decimal(10, 2)` works natively on MySQL.
//   • `Json` works on MySQL 5.7+ / 8+.
//   • The default `utf8mb4_unicode_ci` collation is case-insensitive, so
//     `contains` queries don't need Prisma's `mode: "insensitive"` flag
//     (which is PostgreSQL-only and would throw on MySQL).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & roles
// ---------------------------------------------------------------------------
// Three roles in the system:
//   CUSTOMER  — default; can browse, cart, order, review.
//   MODERATOR — can create products. Edits/deletes are restricted to their
//               own creations. Tracked by Product.createdById.
//   ADMIN     — full control: edit/delete any product, manage users & orders,
//               view audit log.
enum Role {
  CUSTOMER
  MODERATOR
  ADMIN
}

// User record. Auth.js (NextAuth) writes Account / Session rows linking
// OAuth providers to this row. `passwordHash` is set only for credentials
// (username/email + password) signups.
//
// Identity model: credentials users have BOTH a `username` (unique login
// handle) and a real `email` (unique, required for password reset /
// verification). Login accepts either the username or the email plus the
// password. `username` is nullable because OAuth-created users (Google /
// Facebook) have an email but no username.
model User {
  id            String     @id @default(cuid())
  username      String?    @unique
  email         String     @unique
  name          String?
  image         String?    @db.Text
  emailVerified DateTime?
  passwordHash  String?    @db.Text // bcrypt — null for OAuth-only users
  role          Role       @default(CUSTOMER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts      Account[]
  sessions      Session[]
  productsAdded Product[]   @relation("ProductsCreatedBy")
  orders        Order[]
  reviews       Review[]
  auditEvents   AuditLog[]  @relation("AuditActor")
}

// Auth.js OAuth links — one row per (user, provider).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------
model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  icon      String?   // emoji used in the homepage tiles (optional)
  products  Product[]
}

model Product {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?   @db.Text
  price       Decimal   @db.Decimal(10, 2)
  oldPrice    Decimal?  @db.Decimal(10, 2)
  badge       String?   // e.g. "Sale 50%"
  rating      Float     @default(0)
  // Inventory — `stock` is the source of truth for "is this in stock?"
  stock       Int       @default(0)

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  // Audit: who added this product. Required so moderators can see only their
  // own additions and the admin sees the full history.
  createdById String
  createdBy   User      @relation("ProductsCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  images      ProductImage[]
  reviews     Review[]
  orderItems  OrderItem[]

  @@index([categoryId])
  @@index([createdById])
}

// Each product has 0..N images. We store relative paths under /uploads/...
// because images are served from the same domain.
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String   @db.Text
  alt       String?
  sort      Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sort])
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------
enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  PAYPAL
  AMAZON
  BKASH
  NAGAD
}

model Order {
  id            String        @id @default(cuid())
  number        String        @unique   // ECO-123456 friendly id
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  email         String        // captured for guest orders too
  phone         String?
  firstName     String
  lastName      String
  street        String        @db.Text
  city          String?
  state         String?
  zip           String?
  country       String?

  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  shipping      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  couponCode    String?
  notes         String?       @db.Text

  payment       PaymentMethod @default(COD)
  status        OrderStatus   @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         OrderItem[]

  @@index([userId])
  @@index([status])
}

// Snapshot of price+name at purchase time so historical orders don't change
// when the product is later edited or deleted.
model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  productSlug String   // snapshot
  productName String   // snapshot
  unitPrice   Decimal  @db.Decimal(10, 2)
  qty         Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Reviews
// ---------------------------------------------------------------------------
model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      // 1..5
  body      String   @db.Text
  approved  Boolean  @default(false)   // admin moderates
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Audit log — every privileged write logs here.
// Lets the admin see exactly who did what and when.
// ---------------------------------------------------------------------------
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  action     String   // e.g. "product.create" | "product.update" | "order.refund"
  entity     String   // e.g. "Product" | "Order" | "User"
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}
